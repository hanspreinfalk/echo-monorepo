# Vite injects only vars prefixed with VITE_. Copy to .env.local or .env in this directory.
#
# Base URL of the widget Next app (iframe target). Local dev: http://localhost:3001
VITE_WIDGET_URL=http://localhost:3001

# Convex HTTP site URL for /embed/* routes (same deployment as the dashboard/widget, .site host).
# Example: https://your-deployment.convex.site
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site
