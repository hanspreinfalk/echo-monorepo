# Convex backend — set these in the Convex Dashboard → Settings → Environment Variables
# for each deployment (dev/prod). For local iteration, `pnpm dev` / `convex dev` uses your
# dev deployment; the CLI may also write CONVEX_URL and related entries to .env.local (do not commit).
#
# Clerk — JWT issuer for Convex auth (Clerk dashboard → JWT templates / instance domain).
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# Clerk — secret API key (server-side; also used by some Convex actions).
CLERK_SECRET_KEY=sk_test_...

# OpenAI — chat models and embed proxy (see convex/embedOpenai.ts and agent config).
OPENAI_API_KEY=sk-...

# Stripe — optional; billing and webhooks (see convex/stripe.ts, convex/http.ts).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public web app origin — used when Stripe redirects or builds return URLs (see convex/stripe.ts).
BASE_URL=http://localhost:3000

# Optional — comma-separated Clerk user IDs treated as bootstrap admins (see convex/users.ts).
# ECHO_BOOTSTRAP_ADMIN_CLERK_IDS=user_2abc...,user_2def...
